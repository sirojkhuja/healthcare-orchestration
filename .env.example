APP_NAME=MedFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
TENANCY_HEADER=X-Tenant-Id
REQUEST_ID_HEADER=X-Request-Id
CORRELATION_ID_HEADER=X-Correlation-Id
CAUSATION_ID_HEADER=X-Causation-Id
AUDIT_RETENTION_DAYS=0
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_API_KEY_HEADER=X-API-Key
AUTH_API_KEY_PREFIX=mfk
AUTH_API_KEY_SECRET_BYTES=32
AUTH_MFA_ISSUER=MedFlow
AUTH_MFA_DIGITS=6
AUTH_MFA_PERIOD_SECONDS=30
AUTH_MFA_WINDOW=1
AUTH_MFA_CHALLENGE_TTL_MINUTES=10
AUTH_MFA_RECOVERY_CODES_COUNT=8
AUTH_MFA_RECOVERY_CODE_LENGTH=10
AUTH_JWT_ISSUER=medflow
AUTH_JWT_AUDIENCE=medflow-api
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_SECRET=
IDEMPOTENCY_HEADER=Idempotency-Key
IDEMPOTENCY_REPLAY_HEADER=X-Idempotent-Replay
IDEMPOTENCY_RETENTION_HOURS=24
MEDFLOW_CACHE_NAMESPACE=medflow

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=medflow
DB_USERNAME=medflow
DB_PASSWORD=medflow
DB_SSLMODE=prefer

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
AUTH_GUARD=api

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=attachments
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=medflow

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=medflow
REDIS_PORT=6379
REDIS_SCHEME=tls
REDIS_TLS_VERIFY_PEER=false
REDIS_TLS_VERIFY_PEER_NAME=false
REDIS_TLS_ALLOW_SELF_SIGNED=true
REDIS_PREFIX=medflow

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@medflow.local"
MAIL_FROM_NAME="${APP_NAME}"

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=medflow-app
KAFKA_GROUP_ID=medflow-local
KAFKA_ACKS=1
KAFKA_PRODUCE_RETRY=3
KAFKA_PRODUCE_RETRY_SLEEP=0.1
KAFKA_CONSUMER_POLL_INTERVAL_SECONDS=0.1
KAFKA_CONSUMER_GROUP_RETRY=5
KAFKA_CONSUMER_GROUP_RETRY_SLEEP=1
KAFKA_OUTBOX_BATCH_SIZE=50
KAFKA_OUTBOX_MAX_ATTEMPTS=10
KAFKA_OUTBOX_BACKOFF_SECONDS=5
KAFKA_OUTBOX_BACKOFF_MAX_SECONDS=300

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=medflow-app

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
PAYME_MERCHANT_ID=demo-payme-merchant
PAYME_MERCHANT_KEY=demo-payme-key
PAYME_MERCHANT_LOGIN=Paycom
PAYME_CHECKOUT_BASE_URL=https://checkout.paycom.uz
PAYME_CHECKOUT_LANGUAGE=uz
PAYME_CALLBACK_URL=
PAYME_CALLBACK_TIMEOUT=15000
PAYME_CURRENCY=UZS

CLICK_MERCHANT_ID=46
CLICK_SERVICE_ID=36
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=demo-click-secret
CLICK_PAYMENT_BASE_URL=https://my.click.uz/services/pay
CLICK_RETURN_URL=
CLICK_CARD_TYPE=
UZUM_SERVICE_ID=demo-uzum-service
UZUM_MERCHANT_LOGIN=demo-uzum-login
UZUM_MERCHANT_PASSWORD=demo-uzum-password
UZUM_CONFIRMATION_TIMEOUT_MINUTES=30
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PARSE_MODE=HTML
