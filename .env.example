APP_NAME=MedFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
TENANCY_HEADER=X-Tenant-Id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=medflow
DB_USERNAME=medflow
DB_PASSWORD=medflow
DB_SSLMODE=prefer

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=attachments
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=medflow

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=medflow
REDIS_PORT=6379
REDIS_SCHEME=tls
REDIS_TLS_VERIFY_PEER=false
REDIS_TLS_VERIFY_PEER_NAME=false
REDIS_TLS_ALLOW_SELF_SIGNED=true
REDIS_PREFIX=medflow

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@medflow.local"
MAIL_FROM_NAME="${APP_NAME}"

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=medflow-app
KAFKA_GROUP_ID=medflow-local

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=medflow-app

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
