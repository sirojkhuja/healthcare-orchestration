APP_NAME=MedFlow
APP_ENV=testing
APP_KEY=base64:1Wl4cAXhWMetBiugqf/EGnHTgLKiz3KEMG8MesCVJ1M=
APP_DEBUG=true
APP_URL=http://localhost
TENANCY_HEADER=X-Tenant-Id
REQUEST_ID_HEADER=X-Request-Id
CORRELATION_ID_HEADER=X-Correlation-Id
CAUSATION_ID_HEADER=X-Causation-Id
AUDIT_RETENTION_DAYS=0
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_API_KEY_HEADER=X-API-Key
AUTH_API_KEY_PREFIX=mfk
AUTH_API_KEY_SECRET_BYTES=32
AUTH_MFA_ISSUER="MedFlow Testing"
AUTH_MFA_DIGITS=6
AUTH_MFA_PERIOD_SECONDS=30
AUTH_MFA_WINDOW=1
AUTH_MFA_CHALLENGE_TTL_MINUTES=10
AUTH_MFA_RECOVERY_CODES_COUNT=8
AUTH_MFA_RECOVERY_CODE_LENGTH=10
AUTH_JWT_ISSUER=medflow-testing
AUTH_JWT_AUDIENCE=medflow-api
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_SECRET=
IDEMPOTENCY_HEADER=Idempotency-Key
IDEMPOTENCY_REPLAY_HEADER=X-Idempotent-Replay
IDEMPOTENCY_RETENTION_HOURS=24
MEDFLOW_CACHE_NAMESPACE=medflow

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
AUTH_GUARD=api

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array
CACHE_PREFIX=medflow-testing

MAIL_MAILER=array
MAIL_FROM_ADDRESS="testing@medflow.local"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=medflow
REDIS_PORT=6379
REDIS_SCHEME=tls
REDIS_TLS_VERIFY_PEER=false
REDIS_TLS_VERIFY_PEER_NAME=false
REDIS_TLS_ALLOW_SELF_SIGNED=true

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=medflow-testing
KAFKA_GROUP_ID=medflow-testing
KAFKA_ACKS=1
KAFKA_PRODUCE_RETRY=1
KAFKA_PRODUCE_RETRY_SLEEP=0.01
KAFKA_CONSUMER_POLL_INTERVAL_SECONDS=0.01
KAFKA_CONSUMER_GROUP_RETRY=1
KAFKA_CONSUMER_GROUP_RETRY_SLEEP=0.01
KAFKA_OUTBOX_BATCH_SIZE=25
KAFKA_OUTBOX_MAX_ATTEMPTS=3
KAFKA_OUTBOX_BACKOFF_SECONDS=1
KAFKA_OUTBOX_BACKOFF_MAX_SECONDS=5
