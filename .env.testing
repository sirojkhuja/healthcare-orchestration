APP_NAME=MedFlow
APP_ENV=testing
APP_KEY=base64:1Wl4cAXhWMetBiugqf/EGnHTgLKiz3KEMG8MesCVJ1M=
APP_DEBUG=true
APP_URL=http://localhost
TENANCY_HEADER=X-Tenant-Id
REQUEST_ID_HEADER=X-Request-Id
CORRELATION_ID_HEADER=X-Correlation-Id
CAUSATION_ID_HEADER=X-Causation-Id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array
CACHE_PREFIX=medflow-testing

MAIL_MAILER=array
MAIL_FROM_ADDRESS="testing@medflow.local"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=medflow
REDIS_PORT=6379
REDIS_SCHEME=tls
REDIS_TLS_VERIFY_PEER=false
REDIS_TLS_VERIFY_PEER_NAME=false
REDIS_TLS_ALLOW_SELF_SIGNED=true

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=medflow-testing
KAFKA_GROUP_ID=medflow-testing
